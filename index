<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2026 Salary Adjustment Schedule</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- React & Babel CDNs -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50">
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        const App = () => {
            const [selectedDate, setSelectedDate] = useState(null);
            const containerRef = useRef(null);
            const [arrowCoords, setArrowCoords] = useState(null);

            // Project Phase Definitions (Shifted down by 1 week)
            const projectPhases = [
                {
                    week: 'Week 1',
                    start: '2026-03-09',
                    end: '2026-03-13',
                    title: 'Project Kick-off',
                    color: 'bg-blue-500',
                    lightColor: 'bg-blue-50',
                    borderColor: 'border-blue-200',
                    icon: 'clipboard-list',
                    points: ['Confirm scope and eligibility', 'Collect current salary data']
                },
                {
                    week: 'Week 2',
                    start: '2026-03-16',
                    end: '2026-03-20',
                    title: 'Budget & Comparison',
                    color: 'bg-purple-500',
                    lightColor: 'bg-purple-50',
                    borderColor: 'border-purple-200',
                    icon: 'wallet',
                    points: ['Establish total adjustment budget', 'Develop and compare adjustment scenarios']
                },
                {
                    week: 'Week 3',
                    start: '2026-03-23',
                    end: '2026-03-27',
                    title: 'Final Plan & Alignment',
                    color: 'bg-amber-500',
                    lightColor: 'bg-amber-50',
                    borderColor: 'border-amber-200',
                    icon: 'users',
                    points: ['Finalize adjustment plan', 'Review and confirm individual allocations', 'Align with department managers']
                },
                {
                    week: 'Week 4',
                    start: '2026-03-30',
                    end: '2026-04-03',
                    title: 'Implementation',
                    color: 'bg-emerald-500',
                    lightColor: 'bg-emerald-50',
                    borderColor: 'border-emerald-200',
                    icon: 'settings',
                    points: ['Obtain final approval', 'Update payroll system']
                }
            ];

            const milestones = {
                '2026-04-06': { label: 'Effective Date', type: 'effective' },
                '2026-04-23': { label: 'Payday (Adjusted)', type: 'payday' }
            };

            const days = [];
            // March
            for (let i = 1; i <= 31; i++) {
                const fullDate = `2026-03-${i.toString().padStart(2, '0')}`;
                const dateObj = new Date(2026, 2, i);
                const phase = projectPhases.find(p => fullDate >= p.start && fullDate <= p.end);
                days.push({ day: i, month: 'March', fullDate, isWeekend: dateObj.getDay() === 0 || dateObj.getDay() === 6, phase, milestone: milestones[fullDate] });
            }
            // April - Extended to 25 to show the Payday milestone
            for (let i = 1; i <= 25; i++) {
                const fullDate = `2026-04-${i.toString().padStart(2, '0')}`;
                const dateObj = new Date(2026, 3, i);
                const phase = projectPhases.find(p => fullDate >= p.start && fullDate <= p.end);
                days.push({ day: i, month: 'April', fullDate, isWeekend: dateObj.getDay() === 0 || dateObj.getDay() === 6, phase, milestone: milestones[fullDate] });
            }

            useEffect(() => {
                const calculateArrow = () => {
                    const startEl = document.getElementById('date-2026-04-23');
                    const endEl = document.getElementById('date-2026-04-06');
                    const container = containerRef.current;

                    if (startEl && endEl && container) {
                        const startRect = startEl.getBoundingClientRect();
                        const endRect = endEl.getBoundingClientRect();
                        const containerRect = container.getBoundingClientRect();

                        setArrowCoords({
                            x1: startRect.left + startRect.width / 2 - containerRect.left,
                            y1: startRect.top + startRect.height / 2 - containerRect.top,
                            x2: endRect.left + endRect.width / 2 - containerRect.left,
                            y2: endRect.top + endRect.height / 2 - containerRect.top
                        });
                    }
                };

                if (window.lucide) window.lucide.createIcons();
                
                calculateArrow();
                window.addEventListener('resize', calculateArrow);
                return () => window.removeEventListener('resize', calculateArrow);
            }, [selectedDate]);

            const selectedDayData = days.find(d => d.fullDate === selectedDate);
            const weekdays = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

            return (
                <div className="min-h-screen p-4 md:p-8">
                    <div ref={containerRef} className="max-w-5xl mx-auto bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-100 relative">
                        
                        {/* SVG Overlay for Retroactive Path */}
                        {arrowCoords && (
                            <svg className="absolute inset-0 pointer-events-none z-20 w-full h-full">
                                <defs>
                                    <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
                                        <polygon points="0 0, 10 3.5, 0 7" fill="#8b5cf6" />
                                    </marker>
                                </defs>
                                <path 
                                    d={`M ${arrowCoords.x1} ${arrowCoords.y1} C ${arrowCoords.x2} ${arrowCoords.y1}, ${arrowCoords.x2} ${arrowCoords.y1}, ${arrowCoords.x2} ${arrowCoords.y2}`}
                                    stroke="#8b5cf6" strokeWidth="3" fill="none" strokeDasharray="8,6" markerEnd="url(#arrowhead)" className="opacity-40"
                                />
                                <text x={arrowCoords.x2 + 10} y={arrowCoords.y1 - 10} className="fill-violet-600 text-[11px] font-black uppercase tracking-widest italic">
                                    Retroactive to Apr 6
                                </text>
                            </svg>
                        )}

                        {/* Header Section */}
                        <div className="bg-slate-900 p-8 text-white relative overflow-hidden">
                            <div className="absolute top-0 right-0 w-64 h-64 bg-indigo-500/10 rounded-full -mr-20 -mt-20 blur-3xl"></div>
                            <div className="relative z-10">
                                <div className="flex flex-col md:flex-row md:justify-between md:items-center gap-4 mb-6">
                                    <div className="flex items-center space-x-3">
                                        <div className="bg-indigo-500 p-2 rounded-xl text-white">
                                            <i data-lucide="calendar" className="w-6 h-6"></i>
                                        </div>
                                        <h1 className="text-2xl font-bold tracking-tight">2026 Salary Adjustment Schedule</h1>
                                    </div>
                                    <div className="flex items-center space-x-2 bg-white/10 px-4 py-2 rounded-full border border-white/10">
                                        <div className="w-2 h-2 rounded-full bg-violet-400 animate-pulse"></div>
                                        <span className="text-xs font-bold uppercase tracking-widest text-violet-200">Retroactive Applied</span>
                                    </div>
                                </div>
                                
                                <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
                                    {projectPhases.map((p, idx) => (
                                        <div key={idx} className="bg-white/5 border border-white/10 p-3 rounded-2xl flex items-center space-x-3">
                                            <div className={`w-8 h-8 rounded-lg ${p.color} flex items-center justify-center text-white`}>
                                                <i data-lucide={p.icon} className="w-4 h-4"></i>
                                            </div>
                                            <div>
                                                <p className="text-[10px] text-slate-400 font-bold uppercase">{p.week}</p>
                                                <p className="text-xs font-semibold truncate">{p.title}</p>
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        </div>

                        {/* Legend */}
                        <div className="px-8 py-4 bg-slate-50 border-b border-slate-100 flex flex-wrap gap-6 items-center text-[10px] font-black uppercase tracking-wider text-slate-500">
                            <div className="flex items-center gap-2">
                                <div className="w-3 h-3 rounded-sm bg-white border border-slate-300"></div>
                                <span>Work Day</span>
                            </div>
                            <div className="flex items-center gap-2">
                                <div className="w-3 h-3 rounded-sm bg-indigo-50 border border-indigo-100"></div>
                                <span>Weekend</span>
                            </div>
                            <div className="flex items-center gap-2">
                                <div className="w-3 h-3 rounded-sm bg-violet-500"></div>
                                <span>Critical Milestone</span>
                            </div>
                            <div className="flex items-center gap-2 text-violet-600 uppercase">
                                <div className="w-6 h-0.5 border-t-2 border-dashed border-violet-400"></div>
                                <span>Retroactive path</span>
                            </div>
                        </div>

                        {/* Calendar */}
                        <div className="p-4 md:p-8">
                            <div className="grid grid-cols-7 mb-4">
                                {weekdays.map((wd, i) => (
                                    <div key={wd} className={`text-center py-2 text-xs font-black uppercase tracking-widest ${i === 0 || i === 6 ? 'text-rose-500' : 'text-slate-400'}`}>
                                        {wd}
                                    </div>
                                ))}
                            </div>

                            <div className="grid grid-cols-7 gap-2 md:gap-3">
                                {days.map((item, idx) => (
                                    <div 
                                        key={idx}
                                        id={`date-${item.fullDate}`}
                                        onClick={() => setSelectedDate(item.fullDate)}
                                        className={`
                                            relative h-24 md:h-32 p-3 rounded-2xl transition-all duration-300 cursor-pointer group border flex flex-col justify-between
                                            ${item.isWeekend ? 'bg-indigo-50/30 border-slate-50 opacity-60' : 'bg-white border-slate-100 hover:border-indigo-400 hover:shadow-xl'}
                                            ${item.milestone ? 'ring-2 ring-violet-500 ring-offset-2 z-10 shadow-lg' : ''}
                                            ${selectedDate === item.fullDate ? 'ring-2 ring-slate-900 bg-white scale-105 z-30' : ''}
                                        `}
                                    >
                                        {item.phase && <div className={`absolute top-0 left-3 right-3 h-1 rounded-b-full ${item.phase.color}`}></div>}

                                        <div className="flex justify-between items-start">
                                            <span className={`text-xl font-black ${item.isWeekend ? 'text-slate-200' : 'text-slate-800'}`}>{item.day}</span>
                                            {item.milestone && (
                                                <div className="bg-violet-600 p-1 rounded-lg shadow-lg">
                                                    <i data-lucide={item.milestone.type === 'effective' ? 'check-circle' : 'banknote'} className="w-3 h-3 text-white"></i>
                                                </div>
                                            )}
                                        </div>

                                        <div className="mt-1">
                                            {item.milestone ? (
                                                <div className="flex flex-col">
                                                    <span className="text-[9px] font-black text-violet-600 uppercase leading-none mb-1">Milestone</span>
                                                    <p className="text-[10px] font-black text-slate-800 leading-tight">{item.milestone.label}</p>
                                                </div>
                                            ) : item.phase ? (
                                                <div className="flex flex-col gap-1">
                                                    <span className={`text-[9px] font-bold uppercase ${item.phase.color.replace('bg-', 'text-')}`}>{item.phase.week}</span>
                                                    <p className="text-[9px] font-bold text-slate-500 truncate">{item.phase.title}</p>
                                                </div>
                                            ) : item.day === 1 && (
                                                <span className="text-[10px] bg-slate-800 text-white px-2 py-0.5 rounded-full font-bold uppercase">{item.month}</span>
                                            )}
                                        </div>
                                        <div className="mt-auto opacity-0 group-hover:opacity-100 transition-opacity"><span className="text-[8px] font-bold text-slate-300 uppercase">View</span></div>
                                    </div>
                                ))}
                            </div>
                        </div>
                        <div className="p-4 bg-slate-50 text-center text-slate-400 text-[10px] font-bold uppercase tracking-widest border-t">© 2026 Project Tracker V1.0</div>
                    </div>

                    {/* Modal */}
                    {selectedDate && (
                        <div className="fixed inset-0 bg-slate-900/60 backdrop-blur-md z-50 flex items-center justify-center p-4">
                            <div className="bg-white rounded-[2.5rem] shadow-2xl max-w-md w-full overflow-hidden animate-in fade-in slide-in-from-bottom-8 duration-300">
                                {selectedDayData?.milestone ? (
                                    <div>
                                        <div className="bg-violet-600 p-8 text-white">
                                            <div className="flex justify-between items-start mb-4">
                                                <div className="bg-white/20 p-3 rounded-2xl"><i data-lucide={selectedDayData.milestone.type === 'effective' ? 'check-circle' : 'banknote'} className="w-8 h-8"></i></div>
                                                <button onClick={() => setSelectedDate(null)} className="text-white/60 hover:text-white"><i data-lucide="x" className="w-6 h-6"></i></button>
                                            </div>
                                            <h3 className="text-3xl font-black mb-1 leading-none">{selectedDayData.milestone.label}</h3>
                                            <p className="text-white/80 font-bold">{selectedDayData.fullDate}</p>
                                        </div>
                                        <div className="p-8">
                                            <div className="bg-violet-50 p-6 rounded-3xl border border-violet-100"><p className="font-bold text-sm leading-relaxed text-violet-800">
                                                {selectedDayData.milestone.type === 'effective' ? "Official trigger for all salary changes. Calculations switch to new rates from this day forward." : "First payment deployment with adjusted rates. Includes retroactive sum for the back-dated period."}
                                            </p></div>
                                        </div>
                                    </div>
                                ) : selectedDayData?.phase ? (
                                    <div>
                                        <div className={`${selectedDayData.phase.color} p-8 text-white`}>
                                            <div className="flex justify-between items-start mb-4">
                                                <h3 className="text-3xl font-black">{selectedDayData.phase.week}</h3>
                                                <button onClick={() => setSelectedDate(null)} className="text-white/60 hover:text-white"><i data-lucide="x" className="w-6 h-6"></i></button>
                                            </div>
                                            <p className="text-white/80 font-bold uppercase tracking-widest text-sm">{selectedDayData.phase.title}</p>
                                        </div>
                                        <div className="p-8 space-y-4">
                                            {selectedDayData.phase.points.map((p, i) => (
                                                <div key={i} className="flex items-start gap-4">
                                                    <div className={`mt-1 w-5 h-5 rounded-full flex items-center justify-center ${selectedDayData.phase.color} bg-opacity-20`}><i data-lucide="check" className={`w-3 h-3 ${selectedDayData.phase.color.replace('bg-', 'text-')}`}></i></div>
                                                    <p className="text-slate-700 font-semibold">{p}</p>
                                                </div>
                                            ))}
                                        </div>
                                    </div>
                                ) : (
                                    <div className="p-12 text-center">
                                        <button onClick={() => setSelectedDate(null)} className="absolute top-8 right-8 text-slate-300 hover:text-slate-800"><i data-lucide="x" className="w-8 h-8"></i></button>
                                        <i data-lucide="coffee" className="w-12 h-12 text-slate-200 mx-auto mb-4"></i>
                                        <h3 className="text-2xl font-black text-slate-800 mb-2">{selectedDate}</h3>
                                        <p className="text-slate-400 font-bold uppercase text-xs tracking-widest">General Operations</p>
                                    </div>
                                )}
                            </div>
                        </div>
                    )}
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
